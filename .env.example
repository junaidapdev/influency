# Copy to .env (repo root) and fill in. Never commit .env.
# Get the InsForge values from: npx @insforge/cli metadata  (after `login` + `link`).

# --- Frontend (apps/web). Vite exposes ONLY VITE_*-prefixed vars to the browser bundle. ---
# VITE_INSFORGE_URL    = oss_host from .insforge/project.json
# VITE_INSFORGE_ANON_KEY = npx @insforge/cli secrets get ANON_KEY  (public anon key — RLS-gated)
VITE_INSFORGE_URL=
VITE_INSFORGE_ANON_KEY=

# --- Backend edge functions (InsForge / Deno). Set as InsForge secrets, NOT via this file. ---
# Listed here for documentation only; do not put real secrets in any committed file.
# OPENAI_API_KEY=        # chunk 07 — Snap screenshot extraction (server-side only)
# INSFORGE_BASE_URL=     # injected into the edge runtime by InsForge
